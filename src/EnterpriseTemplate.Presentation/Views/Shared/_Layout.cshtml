<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Enterprise Template</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body>
    <header class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="Dashboard" asp-action="Index">Enterprise Template</a>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="ms-auto d-flex align-items-center gap-3">
                    <span class="navbar-text text-light">@User.Identity.Name</span>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="mb-0">
                        <button type="submit" class="btn btn-outline-light btn-sm">Log out</button>
                    </form>
                </div>
            }
        </div>
    </header>
    <main class="container py-4">
        @RenderBody()
    </main>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
